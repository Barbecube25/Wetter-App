<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/weather_widget_background"
    android:clickable="true"
    android:focusable="true"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/widget_compact_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/weather_widget_glass_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_compact_metric_temperature"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_compact_metric_temperature_placeholder"
            android:textColor="@color/widget_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_compact_metric_uv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:maxLines="1"
            android:text="@string/widget_compact_metric_uv_placeholder"
            android:textColor="@color/widget_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_compact_metric_thunder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="end"
            android:maxLines="1"
            android:text="@string/widget_compact_metric_thunder_placeholder"
            android:textColor="@color/widget_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_title"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_refresh_content_description"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="@color/widget_text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_day_switcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_header_row"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_day_today"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/weather_widget_toggle_active"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_day_today"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_day_tomorrow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/weather_widget_toggle_inactive"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_day_tomorrow"
            android:textColor="@color/widget_text_tertiary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_main_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_day_switcher"
        android:layout_marginTop="8dp"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_main_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/widget_temperature_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_temp_placeholder"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_weather_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/widget_weather_icon_margin_start"
                    android:text="@string/widget_weather_icon_placeholder"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-5dp"
                android:text="@string/widget_condition_placeholder"
                android:textColor="@color/widget_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_inline_summary_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/weather_widget_glass_panel"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/widget_inline_summary_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_summary_title_today"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_inline_summary_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/widget_summary_placeholder"
                android:textColor="@color/widget_text_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_inline_summary_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_inline_rain_timing_none"
                android:textColor="@color/widget_text_accent"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Invisible placeholder: keeps daily_overview referenced in Java without affecting layout -->
        <LinearLayout
            android:id="@+id/widget_daily_overview"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_temp_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_temp_range_placeholder"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_feels_like"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_feels_like_placeholder"
                android:textColor="@color/widget_text_tertiary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_metrics_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_main_row"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:orientation="vertical">

        <!-- Row 1: Min/Max chip | Wind chip -->
        <LinearLayout
            android:id="@+id/widget_metrics_row_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_metric_minmax"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/weather_widget_chip_minmax"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp"
                android:text="@string/widget_metric_minmax_placeholder"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_metric_wind"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/weather_widget_chip_wind"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp"
                android:text="@string/widget_metric_wind_placeholder"
                android:textColor="@color/widget_text_accent"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2: UV chip | Pollen chip -->
        <LinearLayout
            android:id="@+id/widget_metrics_row_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_metric_uv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/weather_widget_chip_uv_low"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp"
                android:text="@string/widget_metric_uv_placeholder"
                android:textColor="@color/widget_text_uv_low"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_metric_pollen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/weather_widget_chip_pollen_low"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp"
                android:text="@string/widget_metric_pollen_placeholder"
                android:textColor="@color/widget_text_pollen_low"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Thunder: kept for Java compatibility, always hidden -->
        <TextView
            android:id="@+id/widget_metric_thunder"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="@string/widget_metric_thunder_placeholder"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Hourly forecast panel: 4 slots plus 2 extra for expanded widgets -->
    <LinearLayout
        android:id="@+id/widget_hourly_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_metrics_panel"
        android:layout_above="@id/widget_detail_panel"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:weightSum="1">

        <LinearLayout
            android:id="@+id/widget_hourly_row_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="4">

            <!-- Slot 1 -->
            <LinearLayout
                android:id="@+id/widget_hourly_slot_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:background="@drawable/weather_widget_glass_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_hourly_time_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hourly_icon_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_hourly_temp_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_hourly_precip_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Slot 2 -->
            <LinearLayout
                android:id="@+id/widget_hourly_slot_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/weather_widget_glass_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_hourly_time_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hourly_icon_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_hourly_temp_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_hourly_precip_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Slot 3 -->
            <LinearLayout
                android:id="@+id/widget_hourly_slot_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/weather_widget_glass_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_hourly_time_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hourly_icon_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_hourly_temp_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_hourly_precip_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Slot 4 -->
            <LinearLayout
                android:id="@+id/widget_hourly_slot_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:background="@drawable/weather_widget_glass_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_hourly_time_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hourly_icon_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_hourly_temp_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_hourly_precip_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_hourly_row_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/widget_hourly_slot_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/weather_widget_glass_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_hourly_time_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hourly_icon_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_hourly_temp_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_hourly_precip_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_hourly_slot_6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/weather_widget_glass_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_hourly_time_6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hourly_icon_6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛅"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_hourly_temp_6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_hourly_precip_6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_detail_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_metrics_panel"
        android:layout_above="@id/widget_updated_at"
        android:layout_marginTop="8dp"
        android:background="@drawable/weather_widget_glass_panel"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_summary_title_today"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_detail_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/widget_summary_placeholder"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_detail_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/widget_summary_placeholder"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated_at"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="@string/widget_updated_placeholder"
        android:textColor="@color/widget_text_muted"
        android:textSize="10sp" />

</RelativeLayout>
