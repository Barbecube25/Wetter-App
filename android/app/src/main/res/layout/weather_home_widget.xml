<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/weather_widget_background"
    android:clickable="true"
    android:focusable="true"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/widget_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_title"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_refresh_content_description"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#F2FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_day_switcher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_header_row"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <TextView
            android:id="@+id/widget_day_today"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/weather_widget_toggle_active"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_day_today"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_day_tomorrow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/weather_widget_toggle_inactive"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_day_tomorrow"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_main_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_day_switcher"
        android:layout_marginTop="8dp"
        android:gravity="top"
        android:orientation="horizontal"
        android:weightSum="2">

        <LinearLayout
            android:id="@+id/widget_main_left"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/widget_temperature_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_temp_placeholder"
                    android:textColor="@android:color/white"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_weather_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/widget_weather_icon_placeholder"
                    android:textColor="#F2FFFFFF"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-5dp"
                android:text="@string/widget_condition_placeholder"
                android:textColor="#F2FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_daily_overview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/weather_widget_glass_chip"
            android:gravity="center_vertical"
            android:minHeight="72dp"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/widget_temp_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_temp_range_placeholder"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_feels_like"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/widget_feels_like_placeholder"
                android:textColor="#E6FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_metrics_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_main_row"
        android:layout_above="@id/widget_updated_at"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/weather_widget_glass_panel"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/widget_metrics_row_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:id="@+id/widget_metric_rain"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_metric_rain_placeholder"
                android:textColor="#F2FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_metric_uv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_horizontal"
                android:maxLines="1"
                android:text="@string/widget_metric_uv_placeholder"
                android:textColor="#F2FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_metric_wind"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:text="@string/widget_metric_wind_placeholder"
                android:textColor="#F2FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_metrics_row_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/widget_metric_thunder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_metric_thunder_placeholder"
                android:textColor="#F2FFFFFF"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_metric_pollen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:text="@string/widget_metric_pollen_placeholder"
                android:textColor="#F2FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated_at"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="@string/widget_updated_placeholder"
        android:textColor="#CCFFFFFF"
        android:textSize="10sp" />

</RelativeLayout>
