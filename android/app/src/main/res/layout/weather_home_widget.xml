<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/weather_widget_background"
    android:clickable="true"
    android:focusable="true"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/widget_header_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="@string/widget_title"
            android:textAllCaps="true"
            android:textColor="#B3FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_refresh_content_description"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#E6FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_temperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="-2dp"
        android:text="@string/widget_temp_placeholder"
        android:textColor="@android:color/white"
        android:textSize="44sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_condition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@id/widget_temperature"
        android:layout_below="@id/widget_temperature"
        android:layout_marginTop="-4dp"
        android:text="@string/widget_condition_placeholder"
        android:textColor="#E6FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/widget_daily_overview"
        android:layout_width="132dp"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/widget_temperature"
        android:layout_alignParentEnd="true"
        android:background="@drawable/weather_widget_glass_chip"
        android:orientation="vertical"
        android:paddingLeft="8dp"
        android:paddingTop="6dp"
        android:paddingRight="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_temp_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_temp_range_placeholder"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_feels_like"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/widget_feels_like_placeholder"
            android:textColor="#E6FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_metrics_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_condition"
        android:layout_marginTop="6dp"
        android:background="@drawable/weather_widget_glass_panel"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/widget_metric_rain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_metric_rain_placeholder"
            android:textColor="#F2FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_metric_uv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_metric_uv_placeholder"
            android:textColor="#F2FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_metric_wind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_metric_wind_placeholder"
            android:textColor="#F2FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_metric_thunder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_metric_thunder_placeholder"
            android:textColor="#F2FFFFFF"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_metric_pollen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_metric_pollen_placeholder"
            android:textColor="#F2FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated_at"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="@string/widget_updated_placeholder"
        android:textColor="#CCFFFFFF"
        android:textSize="10sp" />

</RelativeLayout>
